#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PYTHON_BIN="${USER_WIDGET_PYTHON:-python3}"
CLI_SCRIPT="${SCRIPT_DIR}/quota_cli.py"

USERNAME="${1:-}"
PROFILE="${2:-all}"
OUTPUT_FORMAT="${3:-table}"

ARGS=()

if [[ -n "${USERNAME}" ]]; then
  ARGS+=(--user "${USERNAME}")
fi

if [[ -n "${PROFILE}" ]]; then
  ARGS+=(--profile "${PROFILE}")
fi

if [[ -n "${OUTPUT_FORMAT}" ]]; then
  ARGS+=(--format "${OUTPUT_FORMAT}")
fi

exec "${PYTHON_BIN}" "${CLI_SCRIPT}" "${ARGS[@]}"
